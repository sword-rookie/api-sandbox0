# Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=clarity
DB_SSL_MODE=prefer

# Security (Required - do not leave empty or use defaults in prod)
JWT_SECRET=your-secure-jwt-secret-here
ENCRYPTION_KEY=your-32-byte-encryption-key-here
STATE_COOKIE_KEY=your-secure-state-cookie-key-here

# Server
APP_PORT=8081
