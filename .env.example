# Database Configuration
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=clarity
DB_SSL_MODE=prefer

# Security (Required - do not leave empty or use defaults in prod)
JWT_SECRET=your-secure-jwt-secret-here
ENCRYPTION_KEY=12345678901234567890123456789012

# Cloud / Dev Configurations
# Set to 'production' to enforce HTTPS/Secure cookies for deployment
GO_ENV=development

# URL of the frontend for CORS settings
FRONTEND_URL=http://localhost:3000
STATE_COOKIE_KEY=your-secure-state-cookie-key-here

# Server
APP_PORT=8081
